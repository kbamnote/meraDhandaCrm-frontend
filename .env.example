# Backend API base URL (Vite proxies /api to the backend in dev; set the full
# URL in production, e.g. https://api.yourdomain.com/api).
VITE_API_BASE=/api

# Socket.IO server URL. Leave blank to use the same origin (Vite proxies
# /socket.io in dev). In production set it to your backend origin if different,
# e.g. https://api.yourdomain.com
VITE_SOCKET_URL=

# Razorpay public key (only the key id — never put the secret here)
VITE_RAZORPAY_KEY_ID=
